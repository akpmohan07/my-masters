<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.FileAppender">
        <file>logs/application.log</file>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="REPORT" class="ch.qos.logback.core.FileAppender">
        <file>logs/report.txt</file>
        <append>false</append>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- ResultsPrinter → file only -->
    <logger name="dev.mohanverse.prime.utility.ResultsPrinter"
            level="INFO"
            additivity="false">
        <appender-ref ref="REPORT"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>


</configuration>