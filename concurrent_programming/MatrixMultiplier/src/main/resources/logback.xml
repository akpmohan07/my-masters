<configuration>

    <!-- Real console output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Full application log file -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/application.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Clean report file — no timestamps, just results -->
    <appender name="REPORT" class="ch.qos.logback.core.FileAppender">
        <file>logs/report.txt</file>
        <append>false</append>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- MatrixMetrics logs to report file only -->
    <logger name="dev.mohanverse.report.ReportPrinter"
            level="INFO"
            additivity="false">
        <appender-ref ref="REPORT"/>
    </logger>

    <!-- Everything else goes to console AND file -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>


</configuration>